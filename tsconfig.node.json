{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "electron.vite.config.ts",
    "vitest.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/renderer/env.d.ts",
    "src/shared/**/*.ts",
    "tests/**/*.d.ts",
    "tests/**/*.ts"
  ]
}
